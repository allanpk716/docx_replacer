<Window x:Class="DocuFiller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DocuFiller.Views"
        mc:Ignorable="d"
        Title="DocuFiller - Word文档批量填充工具" Height="550" Width="900"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    
    <DockPanel>
        <!-- 自定义标题栏 -->
        <Border DockPanel.Dock="Top" Background="#F0F0F0" Height="32"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 应用图标和标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="📄" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="DocuFiller" FontSize="13" FontWeight="Medium"
                               Foreground="#333333" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 图钉按钮 (置顶开关) -->
                <Button Grid.Column="2" x:Name="PinButton"
                        ToolTip="置顶窗口"
                        Command="{Binding ToggleTopmostCommand}"
                        FontSize="16" Padding="8,4" Cursor="Hand"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#888888" VerticalAlignment="Center"
                        Margin="0,0,4,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="PinIcon" Text="📌" FontSize="14"/>
                </Button>

                <!-- 最小化按钮 -->
                <Button Grid.Column="3" Content="─" ToolTip="最小化"
                        Click="MinimizeButton_Click"
                        FontSize="14" Padding="12,4" Cursor="Hand"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#555555" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 关闭按钮 -->
                <Button Grid.Column="4" Content="✕" ToolTip="关闭"
                        Click="CloseButton_Click"
                        FontSize="14" Padding="12,4" Cursor="Hand"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#555555" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="15,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding CurrentVersion, StringFormat='版本 {0}'}"
                           VerticalAlignment="Center" FontSize="12" Foreground="#666666" Margin="0,0,10,0"/>

                <TextBlock Grid.Column="1" x:Name="StatusBarMessage"
                           Text="{Binding ProgressMessage}"
                           VerticalAlignment="Center" FontSize="12" Foreground="#888888"/>

                <TextBlock Grid.Column="2" x:Name="UpdateStatusText"
                           Text="{Binding UpdateStatusMessage}"
                           Foreground="{Binding UpdateStatusBrush}"
                           Visibility="{Binding HasUpdateStatus, Converter={StaticResource BooleanToVisibilityConverter}}"
                           VerticalAlignment="Center" FontSize="12" Cursor="Hand"
                           Margin="15,0,15,0">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding UpdateStatusClickCommand}"/>
                    </TextBlock.InputBindings>
                    <TextBlock.TextDecorations>
                        <TextDecorationCollection>
                            <TextDecoration Location="Underline">
                                <TextDecoration.Pen>
                                    <Pen Brush="{Binding UpdateStatusBrush}" Thickness="1"/>
                                </TextDecoration.Pen>
                            </TextDecoration>
                        </TextDecorationCollection>
                    </TextBlock.TextDecorations>
                </TextBlock>

                <Button Grid.Column="3" Content="⚙" ToolTip="更新源设置"
                        Command="{Binding OpenUpdateSettingsCommand}"
                        FontSize="16" Padding="8,2" Cursor="Hand"
                        Background="Transparent" BorderBrush="#CCCCCC" BorderThickness="1"
                        Foreground="#555555" VerticalAlignment="Center" Margin="5,0,5,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E8E8E8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="4" Content="检查更新"
                        Command="{Binding CheckUpdateCommand}"
                        IsEnabled="{Binding CanCheckUpdate}"
                        FontSize="12" Padding="12,4" Cursor="Hand"
                        Background="Transparent" BorderBrush="#CCCCCC" BorderThickness="1"
                        Foreground="#555555">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E8E8E8"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- 主要内容区域 -->
        <Grid Margin="15">
    <TabControl Margin="0,5,0,5" FontSize="14">
            
            <!-- 关键词替换选项卡 -->
            <TabItem Header="关键词替换" FontSize="14">
                <DockPanel>
                <Grid Margin="10,8" DockPanel.Dock="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 模板文件行 -->
                    <Grid Grid.Row="0" Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="模板文件" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox Grid.Column="1" x:Name="TemplatePathTextBox"
                                 Style="{StaticResource TextBoxStyle}"
                                 Text="{Binding TemplatePath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" FontSize="12" Margin="0,0,5,0"
                                 AllowDrop="True"
                                 PreviewDrop="TemplatePathTextBox_PreviewDrop"
                                 PreviewDragEnter="TemplatePathTextBox_PreviewDragEnter"
                                 PreviewDragLeave="TemplatePathTextBox_PreviewDragLeave"
                                 PreviewDragOver="TemplatePathTextBox_PreviewDragOver"/>
                        <Button Grid.Column="2" Content="浏览" ToolTip="选择模板文件"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BrowseTemplateCommand}"
                                Width="55" Height="28" FontSize="12" Margin="0,0,3,0"/>
                        <Button Grid.Column="3" Content="文件夹" ToolTip="选择包含模板的文件夹"
                                Style="{StaticResource ProcessButton}"
                                Command="{Binding BrowseTemplateFolderCommand}"
                                Width="60" Height="28" FontSize="12"/>
                    </Grid>

                    <!-- 模板信息提示 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="65,0,0,3">
                        <TextBlock Text="{Binding TemplateFolderPath}" FontSize="11" Foreground="#7F8C8D"
                                   Visibility="{Binding TemplateFolderPath, Converter={StaticResource StringToVisibilityConverter}}"
                                   Margin="0,0,10,0"/>
                        <TextBlock FontSize="11" Foreground="#27AE60" FontWeight="Bold"
                                   Visibility="{Binding FoundDocxFilesCount, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="找到 {0} 个DOCX文件">
                                    <Binding Path="FoundDocxFilesCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- 模板拖放提示 -->
                    <TextBlock Grid.Row="2" Text="提示：可将 .docx 文件或文件夹拖放到上方文本框"
                               Margin="65,0,0,2" FontSize="11" Foreground="#AAAAAA"/>

                    <!-- 分隔线 -->
                    <Separator Grid.Row="3" Margin="0,3"/>

                    <!-- 数据文件行 -->
                    <Grid Grid.Row="4" Margin="0,3,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="数据文件" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox Grid.Column="1" x:Name="DataPathTextBox"
                                 Style="{StaticResource TextBoxStyle}"
                                 Text="{Binding DataPath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" FontSize="12" Margin="0,0,5,0"
                                 AllowDrop="True"
                                 PreviewDrop="DataPathTextBox_PreviewDrop"
                                 PreviewDragEnter="DataPathTextBox_PreviewDragEnter"
                                 PreviewDragLeave="DataPathTextBox_PreviewDragLeave"
                                 PreviewDragOver="DataPathTextBox_PreviewDragOver"/>
                        <Button Grid.Column="2" Content="浏览"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BrowseDataCommand}"
                                Width="55" Height="28" FontSize="12"/>
                    </Grid>

                    <!-- 数据类型提示 -->
                    <TextBlock Grid.Row="5" Text="{Binding DataFileTypeDisplay, StringFormat='数据类型: {0}'}"
                               Margin="65,2,0,3" FontSize="11" Foreground="#7F8C8D"
                               Visibility="{Binding DataPath, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- 数据拖放提示 -->
                    <TextBlock Grid.Row="6" Text="提示：可将 Excel 文件拖放到上方文本框"
                               Margin="65,0,0,2" FontSize="11" Foreground="#AAAAAA"/>

                    <!-- 分隔线 -->
                    <Separator Grid.Row="7" Margin="0,3"/>

                    <!-- 输出目录行 -->
                    <Grid Grid.Row="8" Margin="0,3,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="输出目录" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource TextBoxStyle}"
                                 Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" FontSize="12" Margin="0,0,5,0"/>
                        <Button Grid.Column="2" Content="浏览"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BrowseOutputCommand}"
                                Width="55" Height="28" FontSize="12"/>
                    </Grid>

                    <!-- 处理进度区域 -->
                    <StackPanel Grid.Row="9" Margin="0,8,0,0">
                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ProgressMessage}"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding ProgressText}"
                                       VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                        </Grid>
                        <ProgressBar Value="{Binding ProgressPercentage}" Maximum="100"
                                     Height="18" Background="#ECF0F1" Foreground="#3498DB"/>
                    </StackPanel>
                </Grid>

                <!-- 操作按钮区域 -->
                <Grid Margin="10,0,10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Content="开始处理"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding StartProcessCommand}"
                            Width="100" Height="32" FontSize="13" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="取消处理"
                            Style="{StaticResource ProcessButton}"
                            Command="{Binding CancelProcessCommand}"
                            Width="100" Height="32" FontSize="13" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="退出"
                            Style="{StaticResource ProcessButton}"
                            Command="{Binding ExitCommand}"
                            Width="70" Height="32" FontSize="13"/>
                </Grid>
                </DockPanel>
            </TabItem>

            <!-- 审核清理选项卡 -->
            <TabItem Header="审核清理" FontSize="14">
                <DockPanel>
                <Grid Margin="10,8" DockPanel.Dock="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 输出目录行 -->
                    <Grid Grid.Row="0" Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="输出目录" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource TextBoxStyle}"
                                 Text="{Binding CleanupOutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" FontSize="12" Margin="0,0,5,0"/>
                        <Button Grid.Column="2" Content="浏览"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BrowseCleanupOutputCommand}"
                                Width="55" Height="28" FontSize="12" Margin="0,0,3,0"/>
                        <Button Grid.Column="3" Content="打开文件夹"
                                Style="{StaticResource ProcessButton}"
                                Command="{Binding OpenCleanupOutputFolderCommand}"
                                Width="75" Height="28" FontSize="12"/>
                    </Grid>

                    <!-- 分隔线 -->
                    <Separator Grid.Row="1" Margin="0,3"/>

                    <!-- 拖放区域 -->
                    <Border Grid.Row="2" x:Name="CleanupDropZoneBorder"
                             BorderBrush="#CCCCCC" BorderThickness="2"
                             Padding="12" Background="#F9F9F9"
                             AllowDrop="True"
                             Drop="CleanupDropZoneBorder_Drop"
                             DragEnter="CleanupDropZoneBorder_DragEnter"
                             DragLeave="CleanupDropZoneBorder_DragLeave"
                             DragOver="CleanupDropZoneBorder_DragOver"
                             Margin="0,5,0,5" CornerRadius="3">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="将文件或文件夹拖放到此处" FontSize="12" Foreground="#666666" HorizontalAlignment="Center"/>
                            <TextBlock Text="支持 .docx 文件" FontSize="11" Foreground="#999999" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 文件列表 -->
                    <Grid Grid.Row="3" Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ListView Grid.Column="0" ItemsSource="{Binding CleanupFileItems}" SelectionMode="Extended" FontSize="12">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="35" Header=""/>
                                    <GridViewColumn Width="250" Header="文件名" DisplayMemberBinding="{Binding FileName}"/>
                                    <GridViewColumn Width="80" Header="大小" DisplayMemberBinding="{Binding FileSizeDisplay}"/>
                                    <GridViewColumn Width="120" Header="状态" DisplayMemberBinding="{Binding StatusDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <Button Content="移除选中" Width="70" Height="26" FontSize="12" Margin="0,0,0,3"
                                    Command="{Binding RemoveSelectedCleanupCommand}"
                                    Style="{StaticResource ProcessButton}"/>
                            <Button Content="清空列表" Width="70" Height="26" FontSize="12"
                                    Command="{Binding ClearCleanupListCommand}"
                                    Style="{StaticResource ProcessButton}"/>
                        </StackPanel>
                    </Grid>

                    <!-- 进度 -->
                    <StackPanel Grid.Row="4" Margin="0,5,0,0">
                        <TextBlock Text="{Binding CleanupProgressStatus}" FontSize="12" Margin="0,0,0,3"/>
                        <ProgressBar Height="16" Value="{Binding CleanupProgressPercent}" Maximum="100"
                                     Background="#ECF0F1" Foreground="#3498DB"/>
                    </StackPanel>
                </Grid>

                <!-- 操作按钮 -->
                <Grid Margin="10,0,10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Content="开始清理"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding CanStartCleanup}"
                            Command="{Binding StartCleanupCommand}"
                            Width="100" Height="32" FontSize="13" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="退出"
                            Style="{StaticResource ProcessButton}"
                            Command="{Binding CloseCleanupCommand}"
                            Width="70" Height="32" FontSize="13"/>
                </Grid>
                </DockPanel>
            </TabItem>

        </TabControl>
    </Grid>
    </DockPanel>
</Window>