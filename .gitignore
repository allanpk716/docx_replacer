External/update-config.yaml
.no-pushover
External/update-client.exe

# ── GSD baseline (auto-generated) ──
# NOTE: .gsd is NOT blanket-ignored because this project tracks .gsd/ planning
# artifacts (PROJECT.md, DECISIONS.md, REQUIREMENTS.md, milestones/) in git.
# GSD's ensureGitignore() detects tracked files and skips the blanket rule.
.gsd-id

