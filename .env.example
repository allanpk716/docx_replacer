# DocuFiller Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored and will NOT be committed.

# Update Server Connection
UPDATE_SERVER_HOST=
UPDATE_SERVER_PORT=
UPDATE_SERVER_API_TOKEN=

# SSH Deployment (optional, only needed for SSH-based deployment)
UPDATE_SERVER_SSH_PORT=
UPDATE_SERVER_USER=
UPDATE_SERVER_PASSWORD=
