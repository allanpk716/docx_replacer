<Window x:Class="DocuFiller.Views.DownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="下载更新"
        Width="450"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/app.ico"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status text -->
        <TextBlock Grid.Row="0" Text="{Binding StatusText}" FontSize="13" Margin="0,0,0,12"
                   TextWrapping="Wrap"/>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="1"
                     Value="{Binding ProgressPercent, Mode=OneWay}"
                     Minimum="0" Maximum="100"
                     Height="25"
                     Style="{StaticResource ModernProgressBarStyle}"
                     Margin="0,0,0,8"/>

        <!-- Progress info row -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding DownloadSpeed}"
                       FontSize="12" Foreground="Gray" Margin="10,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding RemainingTime, StringFormat='预计剩余 {0}'}"
                       FontSize="12" Foreground="Gray" VerticalAlignment="Center"/>
        </Grid>

        <!-- Cancel button -->
        <Button Grid.Row="3" Content="取消下载"
                Width="100" Height="30" HorizontalAlignment="Right"
                Command="{Binding CancelCommand}"
                Style="{StaticResource PrimaryButtonStyle}"/>
    </Grid>
</Window>
